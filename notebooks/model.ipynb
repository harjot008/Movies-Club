   "source": [
    "# Apply stemming to the tags\n",
    "\n",
    "from nltk.stem.porter import PorterStemmer\n",
    "\n",
    "ps = PorterStemmer()\n",
    "\n",
    "def stem(text):\n",
    "    return \" \".join(\n",
    "        [ps.stem(word) for word in text.split()]\n",
    "    )\n",
    "\n",
    "new_df['tags'] = new_df['tags'].apply(stem)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "12b4da5f",
   "metadata": {},
   "outputs": [
